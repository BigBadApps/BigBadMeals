# GEMINI_API_KEY: Required in production. In development, optional (AI routes warn if missing).
# Also accepted: API_KEY or GOOGLE_API_KEY (see server/config.ts).
GEMINI_API_KEY=""

# PORT: HTTP port for the Express server (default 3000).
PORT="3000"

# REQUIRE_AI_AUTH: When true, /api/ai/* requires a Firebase ID token in the
# Authorization header: `Bearer <token>`.
REQUIRE_AI_AUTH="false"

# VITE_DISABLE_AUTH: Test-only helper to bypass Firebase auth UI in the client.
# Do not enable in production deployments.
VITE_DISABLE_AUTH="false"

# VITE_E2E_AUTH: Used by Playwright (global setup) — signed-in storage state. Leave false for normal dev.
VITE_E2E_AUTH="false"

# VITE_USE_INMEMORY_DB: Test-only helper to replace Firestore with in-memory storage.
# Intended for E2E tests to avoid relying on external services.
VITE_USE_INMEMORY_DB="false"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
